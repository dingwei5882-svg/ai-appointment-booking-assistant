---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Workflow from '../components/Workflow.astro';
import AppointmentForm from '../components/AppointmentForm.astro';
import { workflowSteps } from '../data/workflow';

const features = [
    {
        title: "AI Scheduling",
        description: "Intelligent scheduling that understands natural language and context."
    },
    {
        title: "Calendar Sync",
        description: "Real-time, two-way synchronization with Google, Outlook, and other calendars."
    },
    {
        title: "Automatic Reminders",
        description: "Reduce no-shows with automated email and SMS reminders for all parties."
    }
];
---
<BaseLayout title="AI Appointment Booking Assistant">
    <Hero 
        title="AI Appointment Booking Assistant" 
        subtitle="Automate appointment booking with AI" 
    />
    <section class="container mx-auto py-12 px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {features.map(feature => (
                <FeatureCard title={feature.title} description={feature.description} />
            ))}
        </div>
    </section>
    <Workflow steps={workflowSteps} />
    <AppointmentForm />
</BaseLayout>
